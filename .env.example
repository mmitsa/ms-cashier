# Copy this file to .env and fill in real values. NEVER commit .env to source control.

# SQL Server SA password (min 8 chars, upper, lower, digit, symbol)
SA_PASSWORD=ChangeMe_Strong!Password2026

# JWT signing key — min 32 chars, random, generate with: openssl rand -base64 48
JWT_KEY=ReplaceWithARandom48ByteBase64StringLongerThan32Chars!
JWT_ISSUER=MsCashier
JWT_AUDIENCE=MsCashier
JWT_EXPIRY_HOURS=24

# Allowed CORS origins (comma-separated, no spaces, no wildcards)
CORS_ORIGINS=http://localhost:3000

# ASP.NET environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
